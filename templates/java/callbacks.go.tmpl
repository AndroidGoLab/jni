// that dispatches method calls to the Go callback functions.
func register{{.GoType}}(env *jni.Env, cb {{.GoType}}) (*jni.Object, func(), error) {
	proxy, cleanup, err := env.NewProxy(
		[]*jni.Class{(*jni.Class)(unsafe.Pointer(cls{{.GoType}}))},
		func(env *jni.Env, methodName string, args []*jni.Object) (*jni.Object, error) {
