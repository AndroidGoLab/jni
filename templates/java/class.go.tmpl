{{- if eq .Obtain "system_service"}}

const serviceName = "{{.ServiceName}}"

// {{.GoType}} wraps {{.JavaClass}}.
type {{.GoType}} struct {
	VM  *jni.VM
	Ctx *app.Context
	Obj *jni.GlobalRef
}

// New{{.GoType}} obtains {{.JavaClass}} from the Android system service manager.
func New{{.GoType}}(ctx *app.Context) (*{{.GoType}}, error) {
	if ctx == nil {
		return nil, fmt.Errorf("{{.GoType}}: nil Context")
	}
	var mgr {{.GoType}}
	mgr.VM = ctx.VM
	mgr.Ctx = ctx

	err := mgr.VM.Do(func(env *jni.Env) error {
		if err := ensureInit(env); err != nil {
			return err
		}
		svc, err := ctx.GetSystemService(serviceName)
		if err != nil {
			return err
		}
		if svc == nil || svc.Ref() == 0 {
			return fmt.Errorf("%s service not available", serviceName)
		}
		mgr.Obj = env.NewGlobalRef(svc)
		return nil
	})
	if err != nil {
		return nil, err
	}
	return &mgr, nil
}
{{- end}}
{{- if eq .Obtain "constructor"}}

// {{.GoType}} wraps {{.JavaClass}}.
type {{.GoType}} struct {
	VM  *jni.VM
	Obj *jni.GlobalRef
}

// New{{.GoType}} creates a new {{.JavaClass}} instance.
func New{{.GoType}}(vm *jni.VM) (*{{.GoType}}, error) {
	var t {{.GoType}}
	t.VM = vm

	err := vm.Do(func(env *jni.Env) error {
		if err := ensureInit(env); err != nil {
			return err
		}
		obj, err := env.NewObject((*jni.Class)(unsafe.Pointer(cls{{.GoType}})), mid{{.GoType}}Init)
		if err != nil {
			return err
		}
		t.Obj = env.NewGlobalRef(obj)
		return nil
	})
	if err != nil {
		return nil, err
	}
	return &t, nil
}
{{- end}}
