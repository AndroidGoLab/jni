// Get{{title .GoType}} reads all static fields from {{.JavaClass}}.
func Get{{title .GoType}}(vm *jni.VM) (*{{.GoType}}, error) {
	var info {{.GoType}}
	err := vm.Do(func(env *jni.Env) error {
		if err := ensureInit(env); err != nil {
			return err
		}
		return nil
	})
	if err != nil {
		return nil, err
	}
	return &info, nil
}
