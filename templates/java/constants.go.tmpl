var (
{{range .VarValues}}	{{.GoName}} {{if $grp.GoType}}{{$grp.GoType}} {{else if $grp.BaseType}}{{$grp.BaseType}} {{end}}= {{.Value}}
{{end}})
{{- end}}
{{end}}
