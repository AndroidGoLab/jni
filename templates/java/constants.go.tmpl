import "math"
{{end}}
{{range .ConstantGroups}}{{$grp := .}}
{{if .GoType}}// {{.GoType}} represents a typed constant.
type {{.GoType}} {{.BaseType}}
{{end}}
{{- if .ConstValues}}
const (
{{range .ConstValues}}	{{.GoName}} {{if $grp.GoType}}{{$grp.GoType}} {{else if $grp.BaseType}}{{$grp.BaseType}} {{end}}= {{.Value}}
{{end}})
{{- end}}
